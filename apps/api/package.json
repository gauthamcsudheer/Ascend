{
  "name": "@ascend/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@ascend/db": "workspace:*",
    "@ascend/shared": "workspace:*",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "socket.io": "^4.7.5",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0",
    "pino": "^9.3.0",
    "pino-http": "^10.2.0",
    "argon2": "^0.40.1",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.3.1",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@ascend/config": "workspace:*",
    "dotenv-cli": "^7.4.2",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0"
  }
